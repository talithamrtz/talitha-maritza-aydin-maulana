<div id="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Expanded image preview">
  <button type="button" class="lightbox-close" aria-label="Close lightbox">×</button>
  <img src="" alt="Expanded portfolio image">
</div>

<script>
document.body.classList.add('js-enabled');
const nav = document.querySelector('nav');
const navToggle = document.querySelector('.nav-toggle');
const navLinks = document.querySelectorAll('nav a');

window.addEventListener('scroll', () => {
  if (window.scrollY > 24) nav.classList.add('nav-scrolled');
  else nav.classList.remove('nav-scrolled');
});

navToggle.addEventListener('click', () => {
  const expanded = navToggle.getAttribute('aria-expanded') === 'true';
  navToggle.setAttribute('aria-expanded', String(!expanded));
  nav.classList.toggle('open', !expanded);
});

navLinks.forEach(link => {
  link.addEventListener('click', () => {
    if (nav.classList.contains('open')) {
      nav.classList.remove('open');
      navToggle.setAttribute('aria-expanded', 'false');
    }
  });
});

const sections = document.querySelectorAll('section');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('active');
      const sectionId = entry.target.id;
      navLinks.forEach(link => {
        link.classList.toggle('active', link.getAttribute('href') === `#${sectionId}`);
      });
    }
  });
}, { threshold: 0.35 });
sections.forEach(section => observer.observe(section));

const lightbox = document.getElementById('lightbox-overlay');
const lightboxImage = lightbox.querySelector('img');
const closeBtn = lightbox.querySelector('.lightbox-close');

const typedText = document.querySelector('.typed-text');
const roles = [
  'Project Engineer at Esco Healthcare · She/Her',
  'Instrumentation & Control Engineering Graduate',
  'Project Delivery Specialist',
  'Global Team Coordinator',
];
let roleIndex = 0;
let charIndex = 0;
let typingDelay = 55;
let erasingDelay = 30;
let nextRoleDelay = 1400;
let hero = document.querySelector('.hero');

function typeRole() {
  const currentRole = roles[roleIndex];
  if (charIndex < currentRole.length) {
    typedText.textContent += currentRole.charAt(charIndex);
    charIndex++;
    setTimeout(typeRole, typingDelay);
  } else {
    setTimeout(eraseRole, nextRoleDelay);
  }
}

function eraseRole() {
  if (charIndex > 0) {
    typedText.textContent = typedText.textContent.slice(0, -1);
    charIndex--;
    setTimeout(eraseRole, erasingDelay);
  } else {
    roleIndex = (roleIndex + 1) % roles.length;
    setTimeout(typeRole, 600);
  }
}

typeRole();

// Remove hero parallax interaction so the page does not move with mouse movement.
// hero.addEventListener('mousemove', (event) => {
//   const x = (event.clientX / window.innerWidth - 0.5) * 20;
//   const y = (event.clientY / window.innerHeight - 0.5) * 18;
//   document.querySelector('.hero-content').style.transform = `translate3d(${x}px, ${y}px, 0)`;
// });

// hero.addEventListener('mouseleave', () => {
//   document.querySelector('.hero-content').style.transform = 'translate3d(0, 0, 0)';
// });

document.querySelectorAll('.gallery img').forEach(img => {
  img.addEventListener('click', () => {
    lightboxImage.src = img.src;
    lightboxImage.alt = img.alt;
    lightbox.classList.add('active');
  });
});

closeBtn.addEventListener('click', () => lightbox.classList.remove('active'));
lightbox.addEventListener('click', (event) => {
  if (event.target === lightbox) lightbox.classList.remove('active');
});

window.addEventListener('keydown', (event) => {
  if (event.key === 'Escape' && lightbox.classList.contains('active')) {
    lightbox.classList.remove('active');
  }
});
</script>

</body>
</html>